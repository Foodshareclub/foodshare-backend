{
    email support@foodshare.club
}

# Principal API Endpoint
api.foodshare.club {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    reverse_proxy kong:8000 {
        header_up Host {host}
    }
}

# Legacy Redirect (backend -> api)
backend.foodshare.club {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    redir https://api.foodshare.club{uri} permanent
}

# Supabase Studio (Dashboard)
studio.foodshare.club {
    reverse_proxy studio:3000
}

# Web Application
foodshare.club, www.foodshare.club {
    reverse_proxy foodshare-web:3000
}
