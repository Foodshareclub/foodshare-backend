# Principal API Endpoint (Handles SSL via Cloudflare or direct)
api.foodshare.club, backend.foodshare.club {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    reverse_proxy kong:8000 {
        header_up Host {host}
    }
}

# Supabase Studio (Dashboard)
studio.foodshare.club {
    reverse_proxy studio:3000
}
